# Receipt Categorization System Configuration
# Copy this file to .env and update with your values

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/receipt_categorization

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Categorization Settings
DEFAULT_CONFIDENCE_THRESHOLD=0.7
FUZZY_MATCH_THRESHOLD=80
KEYWORD_CONFIDENCE_WEIGHT=0.5

# Learning Settings
MIN_CONFIRMATIONS_FOR_HIGH_CONFIDENCE=5
AUTO_RETRAIN_THRESHOLD=100  # Retrain ML model after N new confirmations

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags (Phase 2)
ENABLE_ML_MODEL=false
ML_MODEL_PATH=models/categorizer_v1.pkl

# Security (set in production)
SECRET_KEY=your-secret-key-here-change-in-production
API_KEY_ENABLED=false
API_KEY=your-api-key-here
